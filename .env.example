# Supabase (Backend / Auth / DB)
# 비어있으면 "의견 보내기"가 저장 없이 Mixpanel 기록만 남깁니다.
# feedback 테이블 스키마는 README.md 참고.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google 로그인 (Google Cloud Console에서 발급받은 OAuth Client ID)
# 비어있으면 "Google로 계속하기" 버튼이 목업 로그인으로 대체됩니다.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# AI (자연어 검색 파싱 · 리포트 요약 · 비교 코멘트)
# OpenAI 또는 Claude 중 하나를 사용
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 공공 부동산 실거래가 데이터 (공공데이터포털)
PUBLIC_REAL_ESTATE_API_KEY=

# 지도 API (카카오 또는 네이버 중 택 1)
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=
